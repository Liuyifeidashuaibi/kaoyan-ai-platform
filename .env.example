# ==================== 阿里云百炼 / DashScope API ====================
# 在 https://bailian.console.aliyun.com/ 申请 API Key
DASHSCOPE_API_KEY=your_dashscope_api_key_here

# 文本对话模型（考研答疑）
LLM_MODEL=qwen-max-latest

# 多模态视觉模型（图片题识别；预算不足可改为 qwen2.5-vl-7b-instruct）
VL_MODEL=qwen2.5-vl-72b-instruct

# 图片公网 HTTPS 根地址（生产必配，供 DashScope 拉取 /uploads 图片）
# 例：https://kaoyan-ai-api.onrender.com
PUBLIC_BASE_URL=

# OpenAI 兼容模式 Base URL（百炼默认）
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# ==================== 服务配置 ====================
# FastAPI 后端监听地址
API_HOST=0.0.0.0
API_PORT=8000

# 前端跨域来源（Next.js 开发服务器）
CORS_ORIGINS=http://localhost:3000

# ==================== 路径配置 ====================
# 项目根目录（留空则自动检测）
PROJECT_ROOT=

# 公共考研资料目录
PUBLIC_DATA_DIR=data/public

# 用户错题图片存储目录
UPLOAD_DIR=uploads/wrong_questions

# Chroma 向量库持久化目录
CHROMA_PERSIST_DIR=chroma_db

# SQLite 数据库路径
DATABASE_URL=sqlite:///./kaoyan.db

# ==================== RAG 配置 ====================
# 检索返回的文档片段数量
RAG_TOP_K=5

# 嵌入模型（百炼 text-embedding-v3）
EMBEDDING_MODEL=text-embedding-v3

# 嵌入向量维度
EMBEDDING_DIM=1024
