# ==================== 阿里云百炼 / DashScope API ====================
# 在 https://bailian.console.aliyun.com/ 申请 API Key
DASHSCOPE_API_KEY=your_api_key_here

# 文本对话模型（考研答疑 RAG 生成）
LLM_MODEL=qwen3.5-plus
# qwen-plus 免费额度用尽时自动降级到此链
LLM_FALLBACK_MODELS=qwen-turbo

# 视觉 OCR 模型（仅解析图片文字，不直接生成回答）
VL_MODEL=qwen-vl-ocr-latest

# 语音识别 / 语音合成（TTS 默认关闭，前端传 enable_tts=true 才调用）
ASR_MODEL=paraformer-realtime-v2
TTS_MODEL=sambert-zhida-v1
ENABLE_TTS_DEFAULT=false

# 聊天图片/语音上传上限（字节，默认各 5MB）
MAX_IMAGE_UPLOAD_BYTES=5242880
MAX_AUDIO_UPLOAD_BYTES=5242880
MAX_AUDIO_SECONDS=30
MAX_QUERY_CHARS=2000
VISION_MAX_WIDTH=1280

# LLM 生成参数（低温度、限制输出长度）
LLM_MAX_TOKENS=2048
LLM_TEMPERATURE=0.1

# 模型 API 调用超时（秒，默认 120）
MODEL_TIMEOUT_SECONDS=120

# OpenAI 兼容模式 Base URL（百炼默认）
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# ==================== 服务配置 ====================
# FastAPI 后端监听地址
API_HOST=0.0.0.0
API_PORT=8000

# 前端跨域来源（逗号分隔）
# 本地开发 + Vercel 域名；若浏览器直连 Tunnel 域名，也需包含 Vercel 地址
# 例：http://localhost:3000,https://kaoyan-ai-platform.vercel.app
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ==================== 路径配置 ====================
# 项目根目录（留空则自动检测）
PROJECT_ROOT=

# 公共考研资料目录
PUBLIC_DATA_DIR=data/public

# 用户错题图片存储目录
UPLOAD_DIR=uploads/wrong_questions

# Chroma 向量库持久化目录
CHROMA_PERSIST_DIR=chroma_db

# SQLite 数据库路径
DATABASE_URL=sqlite:///./kaoyan.db

# ==================== RAG 配置 ====================
# 检索返回条数（Top3~4）
RAG_TOP_K=4
RAG_SNIPPET_MAX_CHARS=280
RESPONSE_CACHE_TTL_SECONDS=3600
CHAT_HISTORY_MAX_TURNS=12
CHAT_HISTORY_MAX_CHARS=18000
CHAT_IMAGE_CONTEXT_TURNS=8

# 嵌入模型（百炼 text-embedding-v3）
EMBEDDING_MODEL=text-embedding-v3
EMBEDDING_DIM=1024

# 向量切片（Supabase 增量同步）
VECTOR_CHUNK_SIZE=900
VECTOR_CHUNK_OVERLAP=80

# ==================== Supabase（择校数据 + 社区模块）====================
# 后端会从以下位置读取（按顺序）：.env → .env.local → crawler/.env
# 项目里已有 crawler/.env 时可只维护那一处
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# 本地开发：Next.js 代理用 BACKEND_URL；浏览器勿配 NEXT_PUBLIC_API_URL（走同源 /api/*）
BACKEND_URL=http://127.0.0.1:8000
# NEXT_PUBLIC_API_URL=

# 社区迁移：npm run db:migrate:013
# 生产 Render 还需：PUBLIC_BASE_URL=https://你的-api.onrender.com

# ==================== 爬虫 LLM 解析 ====================
CRAWLER_PARSE_MODEL=qwen-plus
CRAWLER_MAX_INPUT_CHARS=8000
CRAWLER_MAX_OUTPUT_TOKENS=1500
