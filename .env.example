# ==================== 阿里云百炼 / 千问 API（AI 聊天必填）====================
# ⚠️ 这是模板文件！真实密钥请写在项目根目录 .env（复制本文件：copy .env.example .env）
# 申请地址：https://bailian.console.aliyun.com/ → API Key
# AI 聊天、错题解析、RAG 都读 .env 里的 DASHSCOPE_API_KEY（不是 .env.local）
DASHSCOPE_API_KEY=your_api_key_here

# 文本对话模型（考研答疑）
LLM_MODEL=qwen-plus-2025-07-28
LLM_FALLBACK_MODELS=qwen-math-turbo,qwen3.5-omni-plus-2026-03-15,deepseek-r1-distill-qwen-7b,qwen3.5-flash

# 视觉 OCR 模型（仅解析图片文字，不直接生成回答）
VL_MODEL=qwen-vl-ocr-latest

# 语音识别 / 语音合成（TTS 默认关闭，前端传 enable_tts=true 才调用）
ASR_MODEL=paraformer-realtime-v2
TTS_MODEL=sambert-zhida-v1
ENABLE_TTS_DEFAULT=false

# 聊天图片/语音上传上限（字节，默认各 5MB）
MAX_IMAGE_UPLOAD_BYTES=5242880
MAX_AUDIO_UPLOAD_BYTES=5242880
MAX_AUDIO_SECONDS=30
MAX_QUERY_CHARS=2000
VISION_MAX_WIDTH=1280

# LLM 生成参数（低温度、限制输出长度）
LLM_MAX_TOKENS=2048
LLM_TEMPERATURE=0.1
# qwen3.5-plus 默认「思考模式」首字很慢；考研答疑建议 false
LLM_ENABLE_THINKING=false

# 模型 API 调用超时（秒，默认 120）
MODEL_TIMEOUT_SECONDS=120

# OpenAI 兼容模式 Base URL（百炼默认）
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# ==================== Translator 独立服务 ====================
# Docker 一键启动时 compose 内访问: http://translator:8100
# 本机直跑时仍用: http://127.0.0.1:8100
TRANSLATOR_SERVICE_URL=http://127.0.0.1:8100
TRANSLATOR_API_KEY=change-me-to-a-secure-key
# translatorai 项目路径（Docker 构建用，需与 start-dev.ps1 一致）
TRANSLATOR_ROOT=E:/Tanslator/translatorai
TRANSLATOR_TIMEOUT_SECONDS=600

# ==================== Translator export email (SMTP) ====================
# Use a transactional provider (Resend, Brevo, SendGrid, Amazon SES).
# You do NOT need your own domain to start — providers give a sandbox sender.
# With your own domain later: verify domain + set SPF/DKIM, then use noreply@yourdomain.com
SMTP_HOST=smtp.resend.com
SMTP_PORT=587
SMTP_USER=resend
SMTP_PASSWORD=your_smtp_api_key
SMTP_FROM=onboarding@resend.dev
SMTP_USE_TLS=true
# Optional: .ttf font for PDF exports with Chinese text (defaults to system font)
PDF_FONT_PATH=

# ==================== 服务配置 ====================
# FastAPI 后端监听地址
API_HOST=0.0.0.0
API_PORT=8000

# 前端跨域来源（逗号分隔）
# 本地开发 + Vercel 域名；若浏览器直连 Tunnel 域名，也需包含 Vercel 地址
# 例：http://localhost:3000,https://kaoyan-ai-platform.vercel.app
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ==================== 路径配置 ====================
# 项目根目录（留空则自动检测）
PROJECT_ROOT=

# 公共考研资料目录
PUBLIC_DATA_DIR=data/public

# 用户错题图片存储目录
UPLOAD_DIR=uploads/wrong_questions

# Chroma 向量库持久化目录
CHROMA_PERSIST_DIR=chroma_db

# SQLite 数据库路径
DATABASE_URL=sqlite:///./kaoyan.db

# ==================== RAG 配置 ====================
# 检索返回条数（Top3~4）
RAG_TOP_K=4
RAG_SNIPPET_MAX_CHARS=280
RESPONSE_CACHE_TTL_SECONDS=3600
CHAT_HISTORY_MAX_TURNS=12
CHAT_HISTORY_MAX_CHARS=18000
CHAT_IMAGE_CONTEXT_TURNS=8

# 嵌入模型（百炼 text-embedding-v3）
EMBEDDING_MODEL=text-embedding-v3
EMBEDDING_DIM=1024

# 向量切片（Supabase 增量同步）
VECTOR_CHUNK_SIZE=900
VECTOR_CHUNK_OVERLAP=80

# ==================== Supabase（择校数据 + 社区模块）====================
# 后端会从以下位置读取（按顺序）：.env → .env.local → crawler/.env
# 项目里已有 crawler/.env 时可只维护那一处
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# 本地开发：Next.js 代理用 BACKEND_URL；浏览器勿配 NEXT_PUBLIC_API_URL（走同源 /api/*）
BACKEND_URL=http://127.0.0.1:8000
# NEXT_PUBLIC_API_URL=

# 社区迁移：npm run db:migrate:013
# 生产 Render 还需：PUBLIC_BASE_URL=https://你的-api.onrender.com

# ==================== 爬虫 LLM 解析 ====================
CRAWLER_PARSE_MODEL=qwen-plus
CRAWLER_MAX_INPUT_CHARS=8000
CRAWLER_MAX_OUTPUT_TOKENS=1500

# ==================== Redis 缓存（本地单机）====================
# Docker Compose 内网: redis://redis:6379/0
# 本机直跑: redis://127.0.0.1:6379/0
REDIS_URL=redis://127.0.0.1:6379/0
CACHE_TTL_SCHOOLS_LIST=1800
CACHE_TTL_SCHOOLS_DETAIL=3600
CACHE_TTL_SCORE_LINES=1800
CACHE_TTL_TRANSLATOR=86400
CACHE_TTL_MEMBERSHIP=86400

# 用户会员额度（本地测试，Redis 缓存当日用量）
MEMBERSHIP_DAILY_TRANSLATE_LIMIT=50
MEMBERSHIP_DAILY_CHAT_LIMIT=200

# ==================== Celery 异步任务 ====================
# Broker/Backend 默认复用 Redis，使用不同 DB 编号隔离
CELERY_BROKER_URL=redis://127.0.0.1:6379/1
CELERY_RESULT_BACKEND=redis://127.0.0.1:6379/2
CELERY_TASK_TIME_LIMIT=3600
CELERY_TASK_SOFT_TIME_LIMIT=3300
CELERY_RESULT_EXPIRES=86400
CELERY_BEAT_ENABLED=true
CELERY_BEAT_CRAWLER_HOUR=3
CELERY_BEAT_CRAWLER_MINUTE=0

# ==================== 英文纠错 / ECDICT / 本地 TTS ====================
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_TEXT_MODEL=qwen2.5-vl:7b-q4_K_M
WORD_LIB_DB_PATH=data/word_lib.db
QWEN3_TTS_ENABLED=false
QWEN3_TTS_SCRIPT=scripts/qwen3_tts_synthesize.py
QWEN3_TTS_MODEL=data/tts/qwen/Qwen3-TTS-12Hz-0.6B-CustomVoice
# Docker backend 调用宿主机 GPU 服务（先运行 .\scripts\setup-tts.ps1 + start-tts-host.ps1）
QWEN3_TTS_HOST_URL=http://host.docker.internal:8200
# 朗读默认 Piper（秒级）；设为 false 时优先 Qwen3 高质量语音
TTS_PREFER_PIPER=true
PIPER_MODEL_US_FEMALE=data/tts/piper/en_US-lessac-medium.onnx
PIPER_MODEL_US_MALE=data/tts/piper/en_US-ryan-medium.onnx
PIPER_MODEL_UK_FEMALE=data/tts/piper/en_GB-alba-medium.onnx
PIPER_MODEL_UK_MALE=data/tts/piper/en_GB-northern_english_male-medium.onnx
