# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# ========== 后端 FastAPI 忽略项 ==========
# 用户上传图片（项目根 uploads/；落盘路径见 backend/app/config.py）
uploads/**
!uploads/**/
!uploads/wrong_questions/.gitkeep
!uploads/chat/.gitkeep
# 若误建在 backend 下也一并忽略
backend/uploads/

# Chroma 向量库持久化
chroma_db/

# SQLite 数据库
*.db
*.sqlite
*.sqlite3
kaoyan.db

# Python 虚拟环境
venv/
.venv/
backend/venv/
backend/.venv/

# Python 缓存（任意层级）
__pycache__/
*.py[cod]
*$py.class
*.pyc
.pytest_cache/
.mypy_cache/
.ruff_cache/
*.egg-info/
dist/
build/

# 环境变量、密钥（保留 .env.example 作模板）
.env
.env.*
!.env.example
.env.local
.env.development.local
.env.production.local

# 爬虫 LLM 解析缓存与临时文件
crawler/parse_cache.json
crawler/crawler_checkpoint.json
crawler/_*.html
crawler/*_sample.*
crawler/zxgg.txt
crawler/raw/
crawler/logs/
crawler/.basic_done

# 爬虫调试/探测脚本（不入库）
crawler/_probe_*.py
crawler/_find_*.py
crawler/_dump_*.py
crawler/_brute_*.py
crawler/_check_*.py
crawler/_audit*.py
crawler/_audit*.json
crawler/_*.js
crawler/_kaoyan_js_snippets.txt

# 第三方复试线 CSV（掌上考研，已禁用导入）
crawler/data/kaoyan_scores*.csv
crawler/data/kaoyan_school_id_map.json
crawler/data/eol_score_index.json
crawler/data/_*.csv
crawler/data/_*.json

# 日志
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# ========== 前端 Next.js 忽略项 ==========
node_modules/
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

.next/
out/
/build
/coverage

# Vercel
.vercel

# Cloudflare Tunnel 本地配置（含 tunnel id / 域名）
cloudflare-tunnel/config.yml
cloudflare-tunnel/.tunnel-url

# TypeScript
*.tsbuildinfo
next-env.d.ts

# ========== 系统/编辑器文件 ==========
.DS_Store
Thumbs.db
*.tmp
*.pem
.idea/
.vscode/*
!.vscode/extensions.json

.vercel
