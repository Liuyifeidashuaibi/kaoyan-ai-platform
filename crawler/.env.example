# 爬虫专用环境变量
# 复制此文件为 .env 并填写真实值

# Supabase 项目 URL（从 Dashboard > Settings > API 获取）
SUPABASE_URL=https://your-project-ref.supabase.co

# Supabase service_role key（具有读写权限，务必保密！）
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# 通义千问解析模型（qwen3.7-plus 额度用尽时换 qwen3.6-plus）
CRAWLER_PARSE_MODEL=qwen3.6-plus
CRAWLER_FALLBACK_MODEL=qwen-plus-2025-07-28
CRAWLER_LONG_MODEL=qwen-long
# 复试线专用模型链（长 PDF 自动优先 qwen-long）
CRAWLER_SCORES_MODELS=qwen3.6-plus,qwen-long,qwen-plus-2025-07-28
