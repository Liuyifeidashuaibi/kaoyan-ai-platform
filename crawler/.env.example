# 爬虫发布脚本环境变量
# 复制为 crawler/.env 或写在项目根 .env.local

# ── 必填：JSON 入库 Supabase + 前端缓存刷新 ─────────────────────
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ── 掌上考研本地数据目录（clawer 输出，默认 E:\Kaoyan\re）──────
KAOYAN_DATA_DIR=E:\Kaoyan\re

# ── 爬虫代码在独立目录，由你本机自行运行 ───────────────────────
# E:\Kaoyan\clawer  — 抓掌上考研，写入 KAOYAN_DATA_DIR
# 每日自动：clawer\start-scheduler.bat 或 daily-sync-and-publish.bat
# 手动爬：  clawer\sync-now.bat（只更新 re，不自动上网站）
# 手动发布：npm run crawler:kaoyan:import
