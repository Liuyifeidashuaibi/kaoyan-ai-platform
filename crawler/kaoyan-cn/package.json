{
  "name": "kaoyan-syl-crawler",
  "version": "1.0.0",
  "description": "Daily crawler for 147 double-first-class (双一流) schools on kaoyan.cn",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "start": "node src/index.js",
    "crawl": "node scripts/run-once.js",
    "crawl:list": "node scripts/run-once.js --list-only",
    "sync": "node scripts/sync-once.js",
    "manifest": "node scripts/build-manifest.js",
    "verify": "node scripts/verify.js"
  },
  "dependencies": {
    "node-cron": "^3.0.3"
  }
}
