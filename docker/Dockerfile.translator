# Translator — optional Docker profile (default: run on host with Ollama GPU)
# Build context: translatorai project root

FROM python:3.11-slim

WORKDIR /app

RUN apt-get update && apt-get install -y --no-install-recommends \
    build-essential \
    ffmpeg \
    && rm -rf /var/lib/apt/lists/*

COPY pyproject.toml README.md ./
COPY src/ src/
COPY config/ config/

RUN pip install --no-cache-dir -e ".[server,video]"

ENV TRANSLATOR_HOST=0.0.0.0
ENV TRANSLATOR_PORT=8100
ENV TRANSLATOR_OLLAMA_BASE_URL=http://host.docker.internal:11434

EXPOSE 8100

CMD ["python", "-m", "translator.server.main"]
